<script>
  function switchTab(tabName) {
    document.querySelectorAll('.tab-content').forEach(tab => {
      tab.classList.remove('active');
    });

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('active');
    });

    document.getElementById(tabName).classList.add('active');
    event.target.closest('.tab-btn').classList.add('active');
  }

  function increaseQuantity() {
    const input = document.getElementById('quantity');
    const max = input.getAttribute('max');
    input.value = Math.min(parseInt(input.value) + 1, parseInt(max));
  }

  function decreaseQuantity() {
    const input = document.getElementById('quantity');
    const min = input.getAttribute('min');
    input.value = Math.max(parseInt(input.value) - 1, parseInt(min));
  }

  function notifyMe() {
    alert('We will notify you when this product is back in stock!');
    console.log('Notification request submitted');
  }
</script>
